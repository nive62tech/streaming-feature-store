# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW_EVENTS=raw-events
KAFKA_TOPIC_FEATURES=computed-features
KAFKA_CONSUMER_GROUP=feature-store-group

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL_SECONDS=3600

# SQLite Offline Store
OFFLINE_STORE_DB_PATH=data/offline_store.db

# MLflow
MLFLOW_TRACKING_URI=./mlruns

# Feature Store API
API_HOST=0.0.0.0
API_PORT=8000

# Drift Detection
DRIFT_CHECK_INTERVAL_MINUTES=5
DRIFT_PSI_THRESHOLD=0.2
DRIFT_KS_THRESHOLD=0.05

# Retraining
MIN_SAMPLES_FOR_RETRAINING=1000
MODEL_VALIDATION_ACCURACY_THRESHOLD=0.75